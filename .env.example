# ---------- تلگرام ----------
# توکن رباتی که از BotFather می‌گیری
TELEGRAM_BOT_TOKEN=
# آیدی عددی گروه مقصد (معمولا منفی است). با اسکریپت get_chat_id.py پیدا می‌شود
TELEGRAM_GROUP_ID=
# گروه پیگیری سفارش‌های رهاشده (اختیاری) — برای دکمه‌ی «پیگیری رهاشده‌ها»
FOLLOWUP_GROUP_ID=
# آیدی عددی اعضای مجاز برای گزارش‌گیری (مدیران)، با ویرگول جدا کن
ADMIN_USER_IDS=
# مقصد گزارش‌های مدیریتی (خلاصه فروش/شیفت)؛ خالی = پیوی تک‌تک مدیران. برای گروه مدیران، آیدی آن گروه
REPORTS_CHAT_ID=

# ---------- ووکامرس ----------
# آدرس فروشگاه، بدون اسلش انتهایی
WOO_URL=https://shop.example.ir
# کلید و سکرت رابط ووکامرس (WooCommerce > Settings > Advanced > REST API)
WOO_CK=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOO_CS=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# سکرت وب‌هوک (در صورت استفاده از وب‌هوک، همین را در ووکامرس هم بگذار)
WOO_WEBHOOK_SECRET=

# ---------- CRM (افزونه‌ی a2-crm-plugin، REST اختصاصی تلگرام) ----------
# پایه‌ی REST که افزونه می‌دهد، شامل …/wp-json/<namespace>/tg
CRM_TG_URL=
# توکن اختصاصی تلگرام (هدر X-A2-Token). تا ست نشود، بخش CRM در ربات خاموش است
CRM_TG_TOKEN=

# ---------- آنالیزِ اینستاگرام (سرویسِ فقط‌خواندنیِ ig-insights؛ اختیاری) ----------
# آدرس و توکنِ سرویسِ آنالیز؛ تا ست نشود، بخشِ اینستاگرام در ربات خاموش است
IG_INSIGHTS_URL=
IG_INSIGHTS_TOKEN=

# ---------- ارزیابیِ گزارشِ کار با هوشِ مصنوعی (اختیاری) ----------
# کلید و مدلِ OpenAI؛ تا ست نشود، ارزیابیِ خودکار خاموش است و فقط ثبتِ گزارش انجام می‌شود
OPENAI_API_KEY=
WT_MODEL=gpt-5.5
WT_MAX_COMPLETION_TOKENS=2000

# ---------- رفتار ----------
# فاصله‌ی هر بار بازخوانی پولینگ به ثانیه
POLL_INTERVAL_SECONDS=60
# فقط سفارش‌های موفق (پرداخت‌شده) درج شوند؛ خالی = همه به جز سطل زباله
POST_STATUSES=processing,completed,deliver,delivered
# وضعیت‌هایی که در گزارش فروش «پرداخت‌شده» حساب می‌شوند
PAID_STATUSES=processing,completed,deliver,delivered
# چند روز عقب‌تر دنبال یادداشت جدید بگرد
NOTE_LOOKBACK_DAYS=14
# حداکثر تعداد عکس محصول در هر آلبوم (سقف تلگرام ۱۰)
MAX_PHOTOS=10
# برچسب واحد پول در کپشن و گزارش‌ها
CURRENCY_LABEL=تومان
# نام نمایشی فروشگاه در پیام‌های مشتری
SHOP_NAME=
# واحد فروشگاه ریال است؛ برای نمایش تومان تقسیم بر ۱۰. برای نمایش خود ریال این را ۱ بگذار
MONEY_DIVISOR=10

# ---------- وب‌هوک (اختیاری) ----------
# تا وقتی URL عمومیِ HTTPS روی سرور نداری، روی false بگذار؛ پولینگ همه‌چیز را پوشش می‌دهد
WEBHOOK_ENABLED=false
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8088
WEBHOOK_PATH=/woo/order

# ---------- ذخیره‌سازی ----------
DB_PATH=data/orderbot.db
