# ---------- تلگرام ----------
# توکن رباتی که از BotFather می‌گیری
TELEGRAM_BOT_TOKEN=
# آیدی عددی گروه مقصد (معمولا منفی است). با اسکریپت get_chat_id.py پیدا می‌شود
TELEGRAM_GROUP_ID=
# آیدی عددی اعضای مجاز برای گزارش‌گیری، با ویرگول جدا کن
ADMIN_USER_IDS=

# ---------- ووکامرس ----------
# آدرس فروشگاه، بدون اسلش انتهایی
WOO_URL=https://shop.example.ir
# کلید و سکرت رابط ووکامرس (WooCommerce > Settings > Advanced > REST API)
WOO_CK=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOO_CS=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# سکرت وب‌هوک (در صورت استفاده از وب‌هوک، همین را در ووکامرس هم بگذار)
WOO_WEBHOOK_SECRET=

# ---------- رفتار ----------
# فاصله‌ی هر بار بازخوانی پولینگ به ثانیه
POLL_INTERVAL_SECONDS=60
# فقط سفارش‌های موفق (پرداخت‌شده) درج شوند؛ خالی = همه به جز سطل زباله
POST_STATUSES=processing,completed
# وضعیت‌هایی که در گزارش فروش «پرداخت‌شده» حساب می‌شوند
PAID_STATUSES=processing,completed
# چند روز عقب‌تر دنبال یادداشت جدید بگرد
NOTE_LOOKBACK_DAYS=14
# حداکثر تعداد عکس محصول در هر آلبوم (سقف تلگرام ۱۰)
MAX_PHOTOS=10
# برچسب واحد پول در کپشن و گزارش‌ها
CURRENCY_LABEL=تومان
# واحد فروشگاه ریال است؛ برای نمایش تومان تقسیم بر ۱۰. برای نمایش خود ریال این را ۱ بگذار
MONEY_DIVISOR=10

# ---------- وب‌هوک (اختیاری) ----------
# تا وقتی URL عمومی روی سرور آلمان نداری، روی false بگذار؛ پولینگ همه‌چیز را پوشش می‌دهد
WEBHOOK_ENABLED=false
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8088
WEBHOOK_PATH=/woo/order

# ---------- ذخیره‌سازی ----------
DB_PATH=data/orderbot.db
